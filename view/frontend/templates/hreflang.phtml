<?php
/** @var \Santi\Hreflang\Block\Hreflang $block */
$links = $block->getHreflangLinks();
if (empty($links)) {
    return;
}
?>
<?php foreach ($links as $link): ?>
<link rel="alternate"
      hreflang="<?= $block->escapeHtmlAttr($link['hreflang']) ?>"
      href="<?= $block->escapeUrl($link['url']) ?>" />
<?php endforeach; ?>